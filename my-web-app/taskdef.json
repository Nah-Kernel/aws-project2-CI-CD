{
  "executionRoleArn": "arn:aws:iam::779035457035:role/production-ecs-task-execution-role",
  "containerDefinitions": [
    {
      "name": "web-container",
      "image": "<IMAGE_PLACEHOLDER>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DB_HOST", "value": "production-postgres.ct2q6ukc2p37.ap-southeast-1.rds.amazonaws.com" },
        { "name": "DB_USER", "value": "db_admin" },
        { "name": "DB_NAME", "value": "webappdb" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/production-ecs-app",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "web"
        }
      }
    }
  ],
  "placementConstraints": [],
  "memory": "512",
  "taskRoleArn": "arn:aws:iam::779035457035:role/production-ecs-task-role",
  "family": "production-ecs-task-def",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "volumes": []
}